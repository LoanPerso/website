# ============================================================================
# Quickfund — environment variables. Copy to .env and fill in real values.
# NEVER commit .env. NEVER hardcode secrets. See CLAUDE.md §12.
# ============================================================================

# --- Supabase Management API (CLI / migrations) — server/CLI only ----------
# One access token covers every project in the org.
SUPABASE_ACCESS_TOKEN=
# Default project the CLI/migrations target = PREPROD (quickfundPreprod).
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# --- Supabase runtime client (browser) — targets PREPROD locally -----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase server-side (privileged, NEVER exposed to browser) -----------
SUPABASE_SERVICE_ROLE_KEY=

# --- PROD project (quickfundProd) ------------------------------------------
# Separate Supabase project, schema-only (no seed). DO NOT use locally.
# On the production host (e.g. Netlify), map these into the runtime vars above:
#   NEXT_PUBLIC_SUPABASE_URL      <- SUPABASE_PROD_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY <- SUPABASE_PROD_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY     <- SUPABASE_PROD_SERVICE_ROLE_KEY
SUPABASE_PROD_PROJECT_REF=
SUPABASE_PROD_DB_PASSWORD=
SUPABASE_PROD_URL=
SUPABASE_PROD_ANON_KEY=
SUPABASE_PROD_SERVICE_ROLE_KEY=

# --- Firebase (optional, long-term storage) --------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Telegram (contact form) -----------------------------------------------
# Create a bot via @BotFather, then set:
# - TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# - TELEGRAM_CHAT_ID=123456789 (your user id / group id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
